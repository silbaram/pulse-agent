{
  "schema_version": "v1",
  "usage_mode": "synthetic_development",
  "data_directory": "/tmp/pulse-agent",
  "evidence_directory": "/tmp/pulse-agent/evidence",
  "docker": {
    "endpoint": "unix:///var/run/docker.sock"
  },
  "admin": {
    "socket_path": "/tmp/pulse-agent/admin.sock",
    "allowed_uids": [1000],
    "allowed_gids": [1000]
  },
  "limits": {
    "max_targets": 1,
    "retention": {
      "max_age": "1h",
      "max_bytes": 1024
    }
  },
  "allowed_targets": [],
  "gemini": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "timeout": "30s",
    "data_processing_mode": "unpaid_or_free",
    "api_key_ref": "env:PULSE_AGENT_GEMINI_API_KEY"
  },
  "webhooks": {
    "ingress": {
      "endpoint": "http://127.0.0.1:8080/ingress",
      "secret_ref": "env:PULSE_AGENT_INGRESS_SECRET"
    },
    "outbound": {
      "endpoint": "http://localhost:8081/outbound",
      "secret_ref": "env:PULSE_AGENT_OUTBOUND_SECRET"
    }
  }
}
